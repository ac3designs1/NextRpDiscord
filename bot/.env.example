# ─── Discord ─────────────────────────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications → Bot → Token
DISCORD_TOKEN=your_bot_token_here

# Application ID from General Information → Application ID
CLIENT_ID=your_application_id_here

# Your Discord server ID (right-click server icon → Copy Server ID)
# Leave empty to register commands globally (takes up to 1 hour to propagate)
GUILD_ID=your_guild_id_here

# Role ID that can use /playtime-reset (right-click role → Copy Role ID)
# Leave empty to require Administrator permission instead
ADMIN_ROLE_ID=your_admin_role_id_here

# ─── Database ─────────────────────────────────────────────────────────────────
# Option A: Railway MySQL plugin → just add the plugin and it auto-injects MYSQL_URL
# MYSQL_URL=mysql://user:pass@host:port/dbname

# Option B: External MySQL (e.g. your FiveM server's DB)
# Make sure port 3306 is open on the server firewall.
DB_HOST=your_fivem_server_ip
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=fivem
