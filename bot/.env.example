# ─── Discord ─────────────────────────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Application (client) ID from the same page
CLIENT_ID=your_application_id_here

# Your Discord server ID (right-click server icon → Copy Server ID)
# Leave empty to register commands globally (takes up to 1 hour)
GUILD_ID=your_guild_id_here

# Role ID that can use /playtime-reset (right-click role → Copy Role ID)
# Leave empty to require Administrator permission instead
ADMIN_ROLE_ID=your_admin_role_id_here

# ─── MySQL ────────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password_here
DB_NAME=fivem
